// 草案任务骨架
// draft 字段(可选):原始需求草稿路径,不一定存在于磁盘,仅作追溯用
// plan 字段:占位文件,待讨论后完善
{
  "<uuid>": {
    "status": "draft",
    "repo": "<repo>",
    "description": "<草案描述>",
    "draft": "~/path/to/requirements-draft.md", // 可选,原始需求草稿路径(不一定存在)
    "plan": "~/.kanban/wave/<repo>/<uuid>/plan.md", // 占位文件
    "created": "<ISO8601>",
    "worktree": {}, // 允许为空;提升到 planned 前必须补齐
  },
}
